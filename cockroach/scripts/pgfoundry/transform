#!/usr/bin/env python3
"""Prepare pgFoundry PostgreSQL dumps for CockroachDB at build time.

Several pgFoundry samples (world, iso3166, frenchtowns, usda, dellstore)
declare ``SET client_encoding = 'LATIN1'`` and ship Latin-1 bytes. CockroachDB
does not implement client_encoding (see crdb issue #35882) and expects UTF-8,
so this shared hook transcodes each file in ``SQL_FILES`` to UTF-8 and strips
that setting. Datasets that need it symlink ``scripts/<dataset>`` to
``scripts/pgfoundry``; the hook is keyed only on ``SQL_FILES``.

For dellstore2 the dump also defines a PL/pgSQL ``new_customer`` helper
function with no data dependency — it is dropped so the schema and COPY data
still load faithfully (mirroring the MySQL pgsql hook, which drops it too).
"""
import os
import re
import sys

DROP_LINE_RE = re.compile(
    r"^\s*SET\s+client_encoding\b",
    re.IGNORECASE,
)
FUNC_START_RE = re.compile(r"^\s*CREATE\s+(OR\s+REPLACE\s+)?FUNCTION\b",
                           re.IGNORECASE)


def drop_function_block(lines: list[str], start: int) -> int:
    """Drop from CREATE [OR REPLACE] FUNCTION through its LANGUAGE ...; line."""
    i = start
    while i < len(lines):
        if re.search(r"\bLANGUAGE\s+\w+\s*;", lines[i], re.IGNORECASE):
            return i + 1
        i += 1
    return start + 1


def transform_file(path: str) -> None:
    raw = open(path, "rb").read()
    try:
        text = raw.decode("latin-1")
    except UnicodeDecodeError:
        text = raw.decode("utf-8")

    out: list[str] = []
    lines = text.splitlines(keepends=True)
    i = 0
    while i < len(lines):
        line = lines[i]
        if DROP_LINE_RE.match(line):
            i += 1
            continue
        if FUNC_START_RE.match(line):
            i = drop_function_block(lines, i)
            continue
        out.append(line)
        i += 1

    open(path, "w", encoding="utf-8").write("".join(out))


def main() -> None:
    sql_files = os.environ.get("SQL_FILES", "").split()
    if not sql_files:
        sys.exit("pgfoundry transform: SQL_FILES is empty")
    for path in sql_files:
        transform_file(path)


if __name__ == "__main__":
    main()
