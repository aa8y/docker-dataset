#!/usr/bin/env python3
"""Hand-translate a PostgreSQL SQL dump into MySQL (MariaDB) at build time.

A number of our datasets only ship as PostgreSQL dumps. Where the dump is plain
DDL + data (no PL/pgSQL, no extensions) the dialect gap is small and mechanical,
so this shared hook rewrites the SQL rather than us carrying a hand-maintained
MySQL fork of each dataset. Every dataset that needs it symlinks its
scripts/<dataset> directory to scripts/pgsql, exactly like the stackexchange
hook is shared across sites; the conversion is dataset-agnostic and keyed only
on $SQL_FILES (the files the build will cat into the init script).

What it does, per file in $SQL_FILES:

  * transcodes the file to UTF-8 (some pgFoundry dumps are Latin-1);
  * converts ``COPY tbl (cols) FROM stdin`` + TEXT-format data + ``\\.`` into
    batched multi-row ``INSERT``s (MySQL has no inline COPY);
  * rewrites types: ``character varying``->``varchar``, ``character``->``char``,
    ``timestamp [without|with] time zone``->``datetime``, ``double precision``->
    ``double``, ``serial``->``int``, ``boolean``->``tinyint(1)``, bare
    ``numeric``->``decimal(20,6)``, and ``text``->``varchar(255)`` (every value
    in the datasets that use this hook fits comfortably; making the column a
    bounded type lets it serve as a primary key / be part of a UNIQUE or be
    referenced, which MySQL forbids for TEXT);
  * drops Postgres-only noise (``SET``, sequences, ``OWNER TO``, ``GRANT`` /
    ``REVOKE``, ``COMMENT ON``, ``WITH/WITHOUT OIDS``, ``DEFAULT nextval(...)``,
    psql ``\\connect`` / ``\\.``), turns ``ALTER TABLE ONLY`` into ``ALTER
    TABLE``, strips ``USING btree`` / ``USING hash`` access-method clauses and
    ``public.`` / ``cd.`` schema qualifiers; and
  * lower-cases table identifiers so a dump that defines ``Regions`` but loads
    ``regions`` (Postgres folds unquoted names) still resolves on a
    case-sensitive MySQL.

The init script runs under ``ANSI_QUOTES`` (so the dump's ``"quoted"`` column
names stay identifiers) and ``NO_BACKSLASH_ESCAPES`` (so backslashes in data are
literal, matching Postgres ``standard_conforming_strings`` and the values this
hook emits), with foreign-key/unique checks off during load.

The generic DATABASE/SCHEMA/USE strip in the Dockerfile transform step runs
before this hook; this hook owns everything dialect-specific.
"""
import glob
import os
import re
import sys

BATCH = 500

PREAMBLE = (
    "SET sql_mode='ANSI_QUOTES,NO_BACKSLASH_ESCAPES';\n"
    "SET foreign_key_checks=0;\n"
    "SET unique_checks=0;\n\n"
)
POSTAMBLE = "\nSET foreign_key_checks=1;\nSET unique_checks=1;\n"

# A COPY header: COPY <table> (<cols>) FROM stdin [DELIMITER 'x'];
COPY_RE = re.compile(
    r"^COPY\s+([^\s(]+)\s*\(([^)]*)\)\s+FROM\s+stdin"
    r"(?:\s+DELIMITER\s+'([^']*)')?\s*;",
    re.IGNORECASE)

# Whole DDL lines that are Postgres-only and have no MySQL equivalent we need.
# USING <method> covers btree/hash (pg_dump) and lsm (the Yugabyte dumps).
DROP_LINE_RE = re.compile(
    r"^\s*(SET\s|SELECT\s+pg_catalog\.setval|GRANT\s|REVOKE\s|COMMENT\s+ON|"
    r"WITHOUT\s+OIDS|USING\s+(btree|hash|lsm)\b|\\connect|\\c\s|\\\.)",
    re.IGNORECASE)

# Multi-line statements to drop wholesale (from this keyword until the line that
# ends the statement with ';'). Sequences are folded into the column type
# (serial->int) and their explicit values come from the data; DOMAIN/TYPE are
# Postgres-only custom types (sportsdb defines an unused `primary_id` domain).
DROP_BLOCK_RE = re.compile(
    r"^\s*(CREATE\s+SEQUENCE|ALTER\s+SEQUENCE|CREATE\s+DOMAIN|CREATE\s+TYPE)\b",
    re.IGNORECASE)

# PL/pgSQL (and other) stored functions have no mechanical MySQL translation, so
# they are dropped wholesale. A function runs from CREATE [OR REPLACE] FUNCTION
# until its trailing `LANGUAGE <lang>;`; its body contains semicolons, so the
# generic ';' terminator can't be used.
FUNC_START_RE = re.compile(r"^\s*CREATE\s+(OR\s+REPLACE\s+)?FUNCTION\b",
                           re.IGNORECASE)
FUNC_END_RE = re.compile(r"\bLANGUAGE\s+\w+\s*;\s*$", re.IGNORECASE)


def transcode(path):
    with open(path, "rb") as fh:
        raw = fh.read()
    try:
        return raw.decode("utf-8")
    except UnicodeDecodeError:
        return raw.decode("latin-1")


def convert_type(line):
    """Rewrite Postgres column types to their MySQL equivalents in one line."""
    line = re.sub(r"(?i)\bcharacter\s+varying\b", "varchar", line)
    line = re.sub(r"(?i)\bcharacter\s*\(", "char(", line)
    line = re.sub(r"(?i)\btimestamp(?:\s*\(\d+\))?(?:\s+with(?:out)?\s+time\s+zone)?\b",
                  "datetime", line)
    line = re.sub(r"(?i)\bdouble\s+precision\b", "double", line)
    line = re.sub(r"(?i)\bbigserial\b", "bigint", line)
    line = re.sub(r"(?i)\bserial\b", "int", line)
    line = re.sub(r"(?i)\bboolean\b", "tinyint(1)", line)
    line = re.sub(r"(?i)\bnumeric\b(?!\s*\()", "decimal(20,6)", line)
    line = re.sub(r"(?i)\bnumeric\s*\(", "decimal(", line)
    line = re.sub(r"(?i)\btext\b", "varchar(255)", line)
    return line


def clean_ddl(line):
    """Apply all dialect fixes to a single DDL/statement line."""
    line = convert_type(line)
    line = re.sub(r"(?i)\bdefault\s+nextval\([^)]*\)", "", line)
    line = re.sub(r"(?i)\balter\s+table\s+only\b", "ALTER TABLE", line)
    line = re.sub(r"(?i)\busing\s+(btree|hash|lsm)\b", "", line)
    line = re.sub(r"(?i)\bwith\s*\(\s*oids[^)]*\)", "", line)
    line = re.sub(r"(?i)\b(public|cd)\.", "", line)
    # Lower-case table identifiers (Postgres folded unquoted names to lower
    # case; a case-sensitive MySQL would otherwise not match data to schema).
    line = re.sub(r"(?i)(create\s+table\s+)(\w+)",
                  lambda m: m.group(1) + m.group(2).lower(), line)
    line = re.sub(r"(?i)(alter\s+table\s+)(\w+)",
                  lambda m: m.group(1) + m.group(2).lower(), line)
    line = re.sub(r"(?i)(references\s+)(\w+)",
                  lambda m: m.group(1) + m.group(2).lower(), line)
    return line


def split_copy_row(line, delim):
    """Split a COPY TEXT row on unescaped delimiters, keeping escape pairs."""
    fields, cur, i, n = [], [], 0, len(line)
    while i < n:
        c = line[i]
        if c == "\\" and i + 1 < n:
            cur.append(line[i:i + 2]); i += 2; continue
        if c == delim:
            fields.append("".join(cur)); cur = []; i += 1; continue
        cur.append(c); i += 1
    fields.append("".join(cur))
    return fields


_UNESCAPE = {"t": "\t", "n": "\n", "r": "\r", "\\": "\\"}


def copy_value(field):
    """Render one COPY field as a MySQL literal (NO_BACKSLASH_ESCAPES rules)."""
    if field == "\\N":
        return "NULL"
    out, i = [], 0
    while i < len(field):
        if field[i] == "\\" and i + 1 < len(field):
            out.append(_UNESCAPE.get(field[i + 1], field[i + 1])); i += 2
        else:
            out.append(field[i]); i += 1
    return "'" + "".join(out).replace("'", "''") + "'"


def convert_file(text, out):
    lines = text.split("\n")
    i, n = 0, len(lines)
    drop_block = drop_func = False
    while i < n:
        line = lines[i]

        if drop_func:
            if FUNC_END_RE.search(line):
                drop_func = False
            i += 1; continue
        if drop_block:
            if ";" in line:
                drop_block = False
            i += 1; continue

        m = COPY_RE.match(line)
        if m:
            table, cols, delim = m.group(1), m.group(2), m.group(3) or "\t"
            table = table.split(".")[-1].lower()
            head = "INSERT INTO {} ({}) VALUES\n".format(table, cols)
            batch = []
            i += 1
            while i < n and lines[i].rstrip() != "\\.":
                row = split_copy_row(lines[i], delim)
                batch.append("(" + ", ".join(copy_value(f) for f in row) + ")")
                if len(batch) >= BATCH:
                    out.write(head + ",\n".join(batch) + ";\n")
                    batch = []
                i += 1
            if batch:
                out.write(head + ",\n".join(batch) + ";\n")
            i += 1  # skip the \. terminator
            continue

        if FUNC_START_RE.match(line):
            drop_func = not FUNC_END_RE.search(line)
            i += 1; continue
        if DROP_BLOCK_RE.match(line):
            drop_block = ";" not in line
            i += 1; continue
        if DROP_LINE_RE.match(line):
            i += 1; continue

        stripped = line.lstrip()
        if stripped.startswith("--") or stripped.startswith("INSERT INTO") or not stripped:
            out.write(line + "\n")  # comments / pre-existing INSERTs pass through
        else:
            out.write(clean_ddl(line) + "\n")
        i += 1


def main():
    files = os.environ.get("SQL_FILES", "").split() or sorted(glob.glob("*.sql"))
    files = [f for f in files if os.path.isfile(f)]
    if not files:
        sys.exit("pgsql transform: no SQL files to convert")

    for idx, path in enumerate(files):
        text = transcode(path)
        with open(path, "w", encoding="utf-8") as out:
            if idx == 0:
                out.write(PREAMBLE)
            convert_file(text, out)
            if idx == len(files) - 1:
                out.write(POSTAMBLE)


if __name__ == "__main__":
    main()
