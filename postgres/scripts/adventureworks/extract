#!/usr/bin/env bash
# AdventureWorks ships its loader and its data from two different upstreams: the
# git repo (EXTRACT_URL) provides install.sql, while the CSV bundle comes from
# Microsoft's AdventureWorks 2014 OLTP release zip, fetched here.
set -e
cd AdventureWorks-for-Postgres
wget -q -O ms.zip https://github.com/Microsoft/sql-server-samples/releases/download/adventureworks/AdventureWorks-oltp-install-script.zip
unzip -q -o ms.zip
rm ms.zip
