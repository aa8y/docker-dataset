#!/usr/bin/env python3
"""Reformat the AdventureWorks 2014 OLTP CSV bundle into the layout that
AdventureWorks-for-Postgres/install.sql expects (tab-delimited rows with
CSV-quoted fields).

Microsoft's current bundle ships in two flavors:

1) Pipe format (Person.csv, BusinessEntity.csv, Document.csv, ...).
   Fields are separated by ``+|``, records by ``&|``, with embedded XML that
   spans multiple lines and may contain literal double quotes. Some columns
   use a literal NUL byte as a NULL placeholder. The upstream update_csvs.rb
   expects UTF-16LE with a BOM and is a no-op on these -- so we reimplement the
   transform here.

2) Tab-delimited (ProductDescription.csv, ProductReview.csv, ...).
   Mostly load directly, but a handful contain unescaped double quotes (e.g.
   inch marks like ``2"``) that fail the upstream ``\\copy ... CSV`` because
   they look like CSV opening quotes. The ProductReview rows additionally span
   multiple physical lines.

Run as the adventureworks transform hook (cwd is the build dir); the CSVs live
in the cloned loader repo, so we operate there. Files are read and written with
newline="" so the on-disk bytes (including any embedded CRLF) round-trip
unchanged -- only the field framing is rewritten.
"""
import glob
import os
import re

# Per-file column counts for multi-line tab records (CREATE TABLE in
# AdventureWorks-for-Postgres/install.sql).
MULTILINE_TAB_COLS = {"ProductReview": 8}

NEEDS_QUOTING = re.compile(r'[\t\r\n"]')


def csv_escape(field):
    if NEEDS_QUOTING.search(field):
        return '"{}"'.format(field.replace('"', '""'))
    return field


def each_line(text):
    """Yield each line including its trailing "\\n", splitting only on "\\n"
    (Ruby String#each_line semantics), so an embedded "\\r" stays in the line."""
    start = 0
    while start < len(text):
        nl = text.find("\n", start)
        if nl == -1:
            yield text[start:]
            return
        yield text[start:nl + 1]
        start = nl + 1


def chomp(line):
    """Strip a single trailing record separator (Ruby String#chomp)."""
    if line.endswith("\r\n"):
        return line[:-2]
    if line.endswith(("\n", "\r")):
        return line[:-1]
    return line


def reformat(content, basename):
    """Return the rewritten file content, or None to leave the file untouched."""
    first_line = next(each_line(content), "")

    if "+|" in first_line:
        # Pipe format: strip NUL bytes, then assemble records by accumulating
        # lines until one ends in `&|`, split on `+|`, escape, emit.
        content = content.replace("\x00", "")
        records = []
        buf = ""
        for line in each_line(content):
            buf += line
            if not buf.rstrip().endswith("&|"):
                continue
            rec = buf.rstrip()[:-2]
            records.append("\t".join(csv_escape(f) for f in rec.split("+|")))
            buf = ""
    elif basename in MULTILINE_TAB_COLS:
        # Tab format with embedded newlines: accumulate lines until the buffered
        # tab count matches one full record, then re-quote.
        expected = MULTILINE_TAB_COLS[basename]
        records = []
        buf = ""
        for line in each_line(content):
            buf += line
            if buf.count("\t") < expected - 1:
                continue
            records.append("\t".join(csv_escape(f) for f in chomp(buf).split("\t")))
            buf = ""
    elif '"' in content:
        # Tab format, single-line records, but at least one field has an
        # unescaped double quote. Re-quote per row.
        records = ["\t".join(csv_escape(f) for f in chomp(line).split("\t"))
                   for line in each_line(content)]
    else:
        return None

    return "\n".join(records) + "\n" if records else ""


def main():
    # The CSVs live in the cloned loader repo, so we operate there.
    os.chdir("AdventureWorks-for-Postgres")
    for csv_file in sorted(glob.glob("./*.csv")):
        with open(csv_file, encoding="utf-8", newline="") as f:
            content = f.read()
        output = reformat(content, os.path.splitext(os.path.basename(csv_file))[0])
        if output is None:
            continue
        with open(csv_file, "w", encoding="utf-8", newline="") as f:
            f.write(output)


if __name__ == "__main__":
    main()
